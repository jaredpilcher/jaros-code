# Jaros runtime state (regenerable / mutable). Source lives in
# .jaros-data/agents, .jaros-data/tools, .jaros-data/config, .jaros-data/schedules.
.jaros-data/inbox/
.jaros-data/outbox/
.jaros-data/processed/
.jaros-data/failed/
.jaros-data/claimed/
.jaros-data/state/
.jaros-data/artifacts/
.jaros-data/status.json
.jaros-data/*.log
.jaros-data/daemon.log

# Real benchmark datasets (large / separately licensed — fetched, not vendored)
evals/benchmarks/

# Python
__pycache__/
*.pyc
.env
evals/benchmarks/*.jsonl
evals/benchmarks/**/*.parquet
evals/benchmarks/*.json
.jcode/

# Claude Code runtime state (keep vendored skills/agents, ignore runtime locks)
.claude/scheduled_tasks.lock
.claude/*.lock
